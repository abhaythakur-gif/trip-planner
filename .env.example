# Places API: 100% FREE - No API key needed!
# Uses Overpass API (OpenStreetMap) - unlimited requests, no registration
# Optional: OpenTripMap key provides additional tourist attraction data
# Leave empty to use only Overpass API (recommended - works great!)
OPENTRIPMAP_API_KEY=

# Weather: Open-Meteo (no key needed)
# Geocoding: Nominatim (no key needed)

# Calendar Integration: NOT IMPLEMENTED YET
# When needed, use iCal/ICS export (no API key required)
# See FREE_APIS_SETUP.md for calendar alternatives

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL (seconds)
CACHE_TTL_FLIGHTS=21600  # 6 hours
CACHE_TTL_HOTELS=43200   # 12 hours
CACHE_TTL_WEATHER=10800  # 3 hours
CACHE_TTL_PLACES=604800  # 7 days

# System Configuration
MAX_REPLAN_ATTEMPTS=3
MAX_WORKFLOW_TIMEOUT=300  # 5 minutes
MIN_BUFFER_PERCENTAGE=0.05  # 5%
MIN_CONFIDENCE_SCORE=70

# API Configuration
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT=5  # requests per minute

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=

# Environment
ENVIRONMENT=development  # development, staging, production
